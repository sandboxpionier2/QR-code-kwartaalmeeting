# Pad naar de SQLite database van de aanmeld-app.
# Standaard: ../Uitnodiging-kwartaalmeeting/data/workshops.sqlite
DB_PATH="../Uitnodiging-kwartaalmeeting/data/workshops.sqlite"

# Meeting ID (matcht met de aanmeld-app; standaard 'default').
MEETING_ID="default"

# Poort waarop de check-in app draait.
PORT=5000

# Publieke URL waar de check-in app draait (wordt in de QR-codes verwerkt).
# Voor op de dag: gebruik een URL die vanaf de telefoons van collega's bereikbaar is
# (bv. via ngrok, intern WiFi IP-adres, of gehoste URL).
PUBLIC_URL="http://localhost:5000"

# Wachtwoord voor het live admin dashboard op /admin.
ADMIN_PASSWORD="Kampen800"

# Algemene informatie die aan elke deelnemer getoond wordt op het welkomstscherm.
WELCOME_INFO_TEXT="Welkom bij de kwartaalmeeting! Loop door naar het centrale plein. De workshops starten om 13:30. Kijk op de borden in de hal voor de zaalindeling."
