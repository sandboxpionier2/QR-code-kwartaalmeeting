# === Firebase / Firestore ===
# Gebruik dezelfde waarden als de aanmeld-app zodat beide apps op
# dezelfde Firestore database werken. De check-in app schrijft alleen
# naar nieuwe sub-collecties (`checkinTokens`, `checkins`) en raakt
# de bestaande `participants` / `meetingStats` niet aan.
FIREBASE_PROJECT_ID="uitnodiging-kwartaalmeeting"

# Optie A (aanbevolen): volledige service account JSON als één env var.
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"..."}'

# Optie B: gesplitste credentials (privé-sleutel: \n als literal backslash-n).
FIREBASE_CLIENT_EMAIL="service-account@uitnodiging-kwartaalmeeting.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"

# === App instellingen ===
# Meeting id dat matcht met de aanmeld-app.
MEETING_ID="default"

# Wachtwoord voor /admin dashboard.
ADMIN_PASSWORD="Kampen800"

# Optioneel maar aanbevolen: extra geheim voor tijdelijke reset-tokens
# als iemand op de gedeelde check-inpagina de verkeerde naam aanklikt.
CHECKIN_RESET_SECRET="zet-hier-een-lang-willekeurig-geheim"

# Algemene tekst die elke deelnemer op het welkomstscherm ziet.
WELCOME_INFO_TEXT="Welkom bij de kwartaalmeeting! Kijk op de borden in de hal voor de zaalindeling."

# Optioneel: expliciet de publieke URL zetten (anders gebruikt Vercel
# automatisch VERCEL_URL voor previews en je custom domain voor prod).
# PUBLIC_URL="https://checkin.voorbeeld.nl"
